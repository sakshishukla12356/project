# ─────────────────────────────────────────────
#  Multi-Cloud Dashboard — Environment Variables
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ── Database ──────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./multicloud.db

# ── AWS ───────────────────────────────────────
# Leave blank to use instance role / environment credential chain
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# ── Azure ─────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# ── GCP ───────────────────────────────────────
# Path to a service-account JSON key file  OR  leave blank for ADC
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=
GCP_BILLING_ACCOUNT_ID=
